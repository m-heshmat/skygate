# Get a free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_free_gemini_key_here

# Which Gemini model to use. Free-tier daily quotas vary by model:
#   gemini-2.5-flash-lite  (default, highest free RPD, good for this workload)
#   gemini-2.5-flash       (smarter but very low free RPD ~ 20/day)
#   gemini-2.0-flash-lite  (alternate quota bucket if you hit 429s)
GEMINI_MODEL=gemini-2.5-flash-lite

# Dataset paths (relative to repo root)
LISTINGS_XLSX=data/real_estate_listings.xlsx
CAMPAIGNS_XLSX=data/marketing_campaigns.xlsx
